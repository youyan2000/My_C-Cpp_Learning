{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
            "label": "缂栬瘧C椤圭洰 (Win64)",
            "command": "H:/GNU_C_Compiler/bin/gcc.exe",
            "args": [
                "-g",
                "H:/C_program/raylib_test/src/raylib_test.c",
                "-I", 
                "H:/C_program/raylib_test/include",
				"-L", 
                "H:/C_tools/raylib/lib",
				"-lraylib",
				"-lwinmm",
                "-lgdi32",
                "-lopengl32",
				"-o", 
                "H:/C_program/raylib_test/bin/program.exe",
                "-m64",  
                "-Wall",  
                "-static-libgcc",  
                "-fexec-charset=GBK" 
            ],
            "options": {
                "cwd": "H:/C_program/raylib_test"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Win64 Console Application"
		}
	]
}