{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "调试C项目 (Win64 - Raylib音乐版)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/program.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/bin",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "H:/GNU_C_Compiler/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "启用gdb美观打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "编译 C 项目 (Win64 - Raylib音频版)",
            "avoidWindowsConsoleRedirection": false,
            "logging": {
                "moduleLoad": false,
                "trace": false
            }
        }
    ]
}
